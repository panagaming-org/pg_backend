{%extends 'base.jinja'%}

{%block title%} Inicio {%endblock%}

{%block content%}
<script src="/static/scripts/commands.js" type="module"></script>
<br><br><br> 
<div id="terminal" class="flex h-150 w-full p-4 text-white-500 flex-col bg-base-300 rounded shadow shadow-green-500 overflow-auto">
    
</div>
<br>
<div class="flex card bg-base-300 rounded-box rounded shadow shadow-green-500 grid h-32 grow place-items-center">
    <form id="command_form" class="flex">
        <input type="hidden" id="passwd" name="passwd" value="{{passwd}}">
        <input type="hidden" id="host" name="host" value="{{console.ip}}">
        <input type="hidden" id="port" name="port" value="{{console.port}}">
        <input id="commandInput" type="text" class="input input-success lg:w-130" />
        <button id="btnSend" class="btn btn-success">Enviar</button>
    </form>
</div>
<script src="/static/scripts/commands.js" type="module"></script>
{%endblock%}